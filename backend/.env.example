PORT=5000
JWT_SECRET=your_jwt_secret_here

# MySQL configuration (for Hostinger production deploy)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=akshar_graphics

# SMTP configuration (for email notifications)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@akshargraphics.com
SMTP_PASS=your_email_password
CONTACT_RECEIVER=akshargraphics15@gmail.com

# Persistent Upload Directory (Optional - defaults to 'backend/uploads' or 'public_html/uploads')
# Set this to a path outside the git repository to prevent Git auto-deploy from wiping uploaded images.
# Example: UPLOAD_DIR=/home/u12345/uploads

# Cloudinary configuration (Optional - fallback to local filesystem uploads if not set)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
